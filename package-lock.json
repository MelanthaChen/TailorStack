      "resolved": "packages/queue",
      "link": true
    },
    "node_modules/@tailorstack/schemas": {
      "resolved": "packages/schemas",
      "link": true
    },
    "node_modules/@tailorstack/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/@tailorstack/worker-jd-parser": {
      "resolved": "workers/jd-parser",
      "link": true
    },
