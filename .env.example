NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info

API_HOST=127.0.0.1
API_PORT=4000
WEB_HOST=127.0.0.1
WEB_PORT=3000
WEB_ORIGIN=http://127.0.0.1:3000
SESSION_SECRET=change-me-in-local-development
SESSION_COOKIE_NAME=tailorstack_session
SESSION_TTL_HOURS=168
AUTH_REPOSITORY_DRIVER=postgres
MAX_UPLOAD_BYTES=5242880

DATABASE_URL=postgres://tailorstack:tailorstack@127.0.0.1:15432/tailorstack
QUEUE_URL=redis://127.0.0.1:6379
OBJECT_STORAGE_DRIVER=minio
OBJECT_STORAGE_BUCKET=tailorstack-local
OBJECT_STORAGE_LOCAL_PATH=.local/object-storage
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=tailorstack
OBJECT_STORAGE_SECRET_ACCESS_KEY=tailorstack-dev
